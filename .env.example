# TiebaMecha 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ==================== 安全配置（必须设置）====================
# 加密密钥用于加密存储的 BDUSS/STOKEN 凭证
# 生成方法:
#   Python: import secrets; print(secrets.token_hex(32))
#   Linux/Mac: openssl rand -hex 32
TIEBA_MECHA_SALT=your_salt_here_at_least_64_hex_chars
TIEBA_MECHA_SECRET_KEY=your_secret_key_here_at_least_64_hex_chars

# ==================== 数据库配置（可选）====================
# 数据库路径（默认: data/tieba_mecha.db）
# TIEBA_MECHA_DB_PATH=/path/to/database.db

# ==================== 日志配置（可选）====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
# TIEBA_MECHA_LOG_LEVEL=INFO

# ==================== 调试模式（可选）====================
# 开启调试模式（仅用于开发）
# TIEBA_MECHA_DEBUG=false
